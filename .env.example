# Polymarket Trading Bot (TypeScript)

# -----------------------------
# Runtime Safety (default safe)
# -----------------------------
DRY_RUN=true

# Runtime selector:
# v1 = legacy bot in src/bot.ts
# v2 = domain-based bot in src/bot-v2
BOT_RUNTIME=v1

# -----------------------------
# Required Authentication
# -----------------------------
# Wallet private key used for signing (0x-prefixed hex)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Optional profile/funder address.
# When set, this is used as the positions address for exposure checks.
# FUNDER=0xYOUR_PROFILE_OR_FUNDER_ADDRESS

# Signature type:
# 0 = EOA wallet
# 1 = Magic/Email proxy wallet
# 2 = Gnosis Safe / proxy signer
SIGNATURE_TYPE=0

# -----------------------------
# Network / API
# -----------------------------
CHAIN_ID=137
CLOB_API_HOST=https://clob.polymarket.com
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
ENABLE_CLOB_WS=true
WS_QUOTES_MAX_AGE_MS=2000
WS_RECONNECT_DELAY_MS=2000
GAMMA_API_BASE_URL=https://gamma-api.polymarket.com
DATA_API_BASE_URL=https://data-api.polymarket.com

# -----------------------------
# Relayer (optional)
# -----------------------------
# If omitted, relayer settlement calls are disabled.
# (Current main loop only uses merge when conditions are met.)
# POLYMARKET_RELAYER_URL=https://relayer-v2.polymarket.com
# POLYGON_RPC=https://polygon-rpc.com

# Optional builder headers for authenticated relayer submit calls.
# Provide either local creds OR remote signer config.
# When using local creds, a secondary credential set can be added for
# failover on confirmed relayer rate-limit errors.
# BUILDER_API_KEY=xxxxxxx-xxx-xxxx-xxx-xxxxxxxxx
# BUILDER_API_SECRET=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
# BUILDER_API_PASSPHRASE=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# BUILDER_API_KEY_2=xxxxxxx-xxx-xxxx-xxx-xxxxxxxxx
# BUILDER_API_SECRET_2=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
# BUILDER_API_PASSPHRASE_2=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# BUILDER_SIGNER_URL=https://your-builder-signer.example.com
# BUILDER_SIGNER_TOKEN=your_remote_builder_token
# Remote signer should accept { method, path, body, timestamp? } and return:
# POLY_BUILDER_API_KEY, POLY_BUILDER_TIMESTAMP, POLY_BUILDER_PASSPHRASE, POLY_BUILDER_SIGNATURE

# Optional Telegram notifications (enabled only when BOTH are provided)
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# TELEGRAM_CHAT_ID=-1001234567890

# -----------------------------
# Trading Defaults
# -----------------------------
MARKET_SLUG_PREFIX=btc-updown-5m
MARKET_INTERVAL_SECONDS=300

ORDER_PRICE=0.46
ORDER_SIZE=5

# Tolerance for considering UP/DOWN positions "equal"
POSITION_EQUALITY_TOLERANCE=0.01

# If time to close <= threshold, trigger force-sell path
FORCE_SELL_THRESHOLD_SECONDS=30

# Main loop sleep between cycles (including skipped/error cycles)
LOOP_SLEEP_SECONDS=10

# Faster polling interval for current entered market management loop.
CURRENT_LOOP_SLEEP_SECONDS=3

# V2 scheduler tuning (optional; used only when BOT_RUNTIME=v2)
# Scheduler heartbeat
SCHEDULER_TICK_SECONDS=1
# Per-task intervals (when unset, V2 falls back to legacy sleep vars above)
# DISCOVERY_INTERVAL_SECONDS=10
# CURRENT_MARKET_INTERVAL_SECONDS=3
# ENTRY_INTERVAL_SECONDS=10
# REDEEM_INTERVAL_SECONDS=60
# TELEGRAM_POLL_INTERVAL_SECONDS=10

# Redeem loop interval
REDEEM_LOOP_SLEEP_SECONDS=60
REDEEM_ENABLED=true
REDEEM_MAX_RETRIES=8
REDEEM_RETRY_BACKOFF_MS=60000
REDEEM_SUCCESS_COOLDOWN_MS=300000
REDEEM_MAX_PER_LOOP=20
# Prune terminal redeem states older than this (7 days default)
REDEEM_TERMINAL_STATE_TTL_MS=604800000

# Sleep after successful paired entry before next cycle
POSITION_RECHECK_SECONDS=60

# Reconciliation window after placing paired entry orders.
# If still imbalanced at timeout, the bot can cancel open entry orders and flatten.
ENTRY_RECONCILE_SECONDS=15
ENTRY_RECONCILE_POLL_SECONDS=3
ENTRY_CANCEL_OPEN_ORDERS=true

# Late-window hedge economics inside FORCE_SELL_THRESHOLD_SECONDS.
# maxHedgePrice = 1 - filledLegAvgPrice - FORCE_WINDOW_FEE_BUFFER - FORCE_WINDOW_MIN_PROFIT_PER_SHARE
FORCE_WINDOW_FEE_BUFFER=0.01
FORCE_WINDOW_MIN_PROFIT_PER_SHARE=0.005

# Continuous missing-leg repricing after partial fill.
# Maker-first outside force window, taker fallback remains in force window.
ENTRY_CONTINUOUS_REPRICE_ENABLED=true
ENTRY_CONTINUOUS_REPRICE_INTERVAL_MS=1500
ENTRY_CONTINUOUS_MIN_PRICE_DELTA=0.002
ENTRY_CONTINUOUS_MAX_DURATION_SECONDS=45
ENTRY_CONTINUOUS_MAKER_OFFSET=0.001

# Profitability-first recovery shaping (linear by time-left outside force window):
# progress = clamp((secondsToClose - FORCE_SELL_THRESHOLD_SECONDS) /
#                   (ENTRY_RECOVERY_HORIZON_SECONDS - FORCE_SELL_THRESHOLD_SECONDS), 0, 1)
# targetMinProfit = FORCE_WINDOW_MIN_PROFIT_PER_SHARE + progress * ENTRY_RECOVERY_EXTRA_PROFIT_MAX
# makerOffset = ENTRY_CONTINUOUS_MAKER_OFFSET + progress * ENTRY_RECOVERY_PASSIVE_OFFSET_MAX
# sizeFraction = 1 - progress * (1 - ENTRY_RECOVERY_MIN_SIZE_FRACTION)
ENTRY_RECOVERY_HORIZON_SECONDS=120
ENTRY_RECOVERY_EXTRA_PROFIT_MAX=0.01
ENTRY_RECOVERY_MIN_SIZE_FRACTION=0.35
ENTRY_RECOVERY_PASSIVE_OFFSET_MAX=0.004

# -----------------------------
# Retry / Timeout
# -----------------------------
REQUEST_TIMEOUT_MS=30000
REQUEST_RETRIES=3
REQUEST_RETRY_BACKOFF_MS=500

# Persisted bot state (tracks entered markets across restarts)
STATE_FILE_PATH=.bot-state.json

# -----------------------------
# Logging
# -----------------------------
LOG_LEVEL=info
