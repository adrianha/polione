# Polymarket Trading Bot Configuration

# API Configuration
GAMMA_API_BASE_URL=https://gamma-api.polymarket.com
CLOB_API_HOST=https://clob.polymarket.com
CLOB_API_BASE = https://clob.polymarket.com
CLOB_WS_URL = wss://ws-subscriptions-clob.polymarket.com/ws/market

# Authentication (REQUIRED for trading)
# Your private key for signing transactions
PRIVATE_KEY=your_private_key_here
POLYGON_RPC=https://go.getblock.us/f3ba334a60f1446c9289381e569b2634
# Blockchain Configuration
# Chain ID: 137 for Polygon mainnet, 80001 for Mumbai testnet
CHAIN_ID=137
SIGNATURE_TYPE=EIP712

# Optional: Funder address if different from private key address
# FUNDER=0x...

# Trading Configuration
MARKET_INTERVAL_SECONDS=300
MARKET_SLUG_PREFIX=btc-updown-5m

# Order Configuration
DEFAULT_ORDER_TYPE=LIMIT
MIN_PRICE=0.0
MAX_PRICE=1.0


ORDER_SIZE = 5
ORDER_PRICE = 0.2

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
# Optional: Set LOG_FILE to write logs to a file
# LOG_FILE=bot.log

# Request Configuration
REQUEST_TIMEOUT=30
REQUEST_RETRIES=3
