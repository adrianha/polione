# Polymarket Trading Bot (TypeScript)

# -----------------------------
# Runtime Safety (default safe)
# -----------------------------
DRY_RUN=true
ENABLE_LIVE_TRADING=false

# -----------------------------
# Required Authentication
# -----------------------------
# Wallet private key used for signing (0x-prefixed hex)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Optional profile/funder address (needed for some signature setups)
# FUNDER=0xYOUR_PROFILE_OR_FUNDER_ADDRESS

# Signature type:
# 0 = EOA wallet
# 1 = Magic/Email proxy wallet
# 2 = Gnosis Safe / proxy signer
SIGNATURE_TYPE=0

# -----------------------------
# Network / API
# -----------------------------
CHAIN_ID=137
CLOB_API_HOST=https://clob.polymarket.com
GAMMA_API_BASE_URL=https://gamma-api.polymarket.com
DATA_API_BASE_URL=https://data-api.polymarket.com

# Optional WebSocket endpoint (if user-channel/market-channel streaming is enabled)
# CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# -----------------------------
# Relayer (optional)
# -----------------------------
# If omitted, merge/redeem is skipped safely.
# POLYMARKET_RELAYER_URL=https://relayer-v2.polymarket.com
# POLYGON_RPC=https://polygon-rpc.com

# -----------------------------
# Trading Defaults
# -----------------------------
MARKET_SLUG_PREFIX=btc-updown-5m
MARKET_INTERVAL_SECONDS=300

ORDER_PRICE=0.46
ORDER_SIZE=5

# Tolerance for considering UP/DOWN positions "equal"
POSITION_EQUALITY_TOLERANCE=0.01

# If time to close <= threshold, trigger force-sell path
FORCE_SELL_THRESHOLD_SECONDS=30

# Block new entries if market is too close to end time
MIN_SECONDS_TO_CLOSE_FOR_ENTRY=60

# Main loop sleep between market cycles/checks
LOOP_SLEEP_SECONDS=10

# Poll interval while monitoring positions within an active market
POSITION_RECHECK_SECONDS=60

# -----------------------------
# Retry / Timeout
# -----------------------------
REQUEST_TIMEOUT_MS=30000
REQUEST_RETRIES=3
REQUEST_RETRY_BACKOFF_MS=500

# -----------------------------
# EV Guard (profitability filter)
# -----------------------------
# Set false to disable EV gating and always attempt entries.
EV_GUARD_ENABLED=true

# Minimum net expected value per share required to place paired entries.
EV_MIN_NET_PER_SHARE=0.01

# Cost estimates used by EV calculation:
# net = (1 - (yesPrice + noPrice)) - (fee + slippage + forcedExit + partialFill)
EV_ESTIMATED_FEE_BPS=0
EV_ESTIMATED_SLIPPAGE_PER_SHARE=0.002
EV_ESTIMATED_FORCE_SELL_PENALTY_PER_SHARE=0.004
EV_ESTIMATED_PARTIAL_FILL_PENALTY_PER_SHARE=0.002

# -----------------------------
# Logging
# -----------------------------
LOG_LEVEL=info
