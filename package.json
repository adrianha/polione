  "dependencies": {
    "@polymarket/clob-client": "^5.7.0",
    "@polymarket/relayer-client": "^4.1.0",
    "dotenv": "^17.3.1",
    "pino": "^10.3.1",
    "undici": "^7.22.0",
    "viem": "^2.47.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
