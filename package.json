{
  "name": "polione",
  "version": "1.0.0",
  "description": "TypeScript Polymarket BTC 5-minute trading bot with safe mode defaults",
  "keywords": [],
  "homepage": "https://github.com/adrianha/polione#readme",
  "bugs": {
    "url": "https://github.com/adrianha/polione/issues"
  },
  "license": "ISC",
  "author": "Adrian Hartanto",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adrianha/polione.git"
  },
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "bot": "pm2 start pm2.config.js",
